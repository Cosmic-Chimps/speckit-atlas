# Keep the packaged .vsix minimal: ship only the bundle and runtime assets.
# The CLI bin (feature 004) ships via npm only. The MCP server (dist/mcp.js) IS bundled
# (feature 007) so the extension can advertise it to VS Code's MCP registry.
dist/cli.js
dist/cli.js.map
.vscode/**
.github/**
.claude/**
scripts/**
out/**
test/**
fixtures/**
specs/**
.specify/**
src/**
node_modules/**
**/*.ts
**/*.map
esbuild.js
tsconfig*.json
eslint.config.js
.prettierrc.json
.prettierignore
.gitignore
CLAUDE.md
**/.DS_Store
*.vsix
